<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⬛ Black Screen"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reproduce YouTube con pantalla negra"
        android:textSize="14sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="40dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚫ Inactivo"
        android:textSize="16sp"
        android:textColor="#CCCCCC"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnToggle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Activar pantalla negra"
        android:textSize="16sp"
        android:backgroundTint="#1E88E5"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Permisos del sistema"
        android:textSize="14sp"
        android:backgroundTint="#333333" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Instrucciones:\n1. Abre YouTube\n2. Reproduce el video\n3. Vuelve aquí y pulsa Activar\n4. La pantalla queda negra pero sigue reproduciendo\n5. Usa el botón flotante o la notificación para quitar"
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginTop="32dp"
        android:lineSpacingMultiplier="1.4" />

</LinearLayout>
